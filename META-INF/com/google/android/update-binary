#!/sbin/sh

OUTFD="/proc/self/fd/$2"
ZIPFILE="$3"
DIR=$(dirname "$ZIPFILE")

# Function to print messages to the user
ui_print() {
  while [ "$1" ]; do
    echo -e "ui_print $1\nui_print" >> "$OUTFD"
    shift
  done
}

ui_print "#####################################################"
ui_print "#######         FLASH DISABLE VBMETA           ######"
ui_print "#####################################################"

sleep 1
ui_print " "

# Extract avbctl from zip to writeable RAM path (/tmp)
ui_print "Extracting avbctl engine to temporary workspace..."
unzip -o "$ZIPFILE" "avbctl" -d "/tmp/"
chmod +x "/tmp/avbctl"

sleep 1
ui_print " "

# Get avbctl status using the extracted engine
VERITY=$(/tmp/avbctl get-verity)
VERIFICATION=$(/tmp/avbctl get-verification)

# Print avb vbmeta status
ui_print "Checking AVB Vbmeta status:"
ui_print "  -> $VERITY"
ui_print "  -> $VERIFICATION"

sleep 1
ui_print " "

# Disable AVB vbmeta verity and verification if enabled
if [[ $VERITY == *disabled* ]]; then
  ui_print "AVB verification is already disabled. Nothing to do."
else
  ui_print "Disabling AVB verity & verification policy..."
  DISABLE_VERITY=$(/tmp/avbctl --force disable-verity)
  DISABLE_VERIFICATION=$(/tmp/avbctl --force disable-verification)
  
  ui_print "  -> ${DISABLE_VERITY%%.*}"
  ui_print "  -> ${DISABLE_VERIFICATION%%.*}"

  sleep 1
  ui_print " "

  ui_print "⚠️ NOTE: If the device bootloops or stays stuck in recovery mode,"
  ui_print "   you may need to perform a 'Format Data' partition operation in TWRP."
fi

# Cleanup temporary files
rm -f "/tmp/avbctl"

# Done
sleep 2
exit 0

